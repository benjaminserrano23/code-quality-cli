{
  "name": "code-quality-cli",
  "version": "1.0.0",
  "description": "CLI tool that analyzes code quality metrics for TypeScript and JavaScript projects",
  "main": "dist/cli.js",
  "bin": {
    "cq": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "code-quality",
    "static-analysis",
    "typescript",
    "cli",
    "complexity"
  ],
  "author": "Benjamín Serrano",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@typescript-eslint/typescript-estree": "^8.58.0",
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "ignore": "^7.0.5",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "vitest": "^4.1.2"
  }
}
